<script>
$(document).ready(function() {
    var activeTab = sessionStorage.getItem('userFormActiveTab') || 0;
    $("#tabs").tabs({
        active: parseInt(activeTab),
        activate: function(event, ui) {
            sessionStorage.setItem('userFormActiveTab', ui.newTab.index());
        }
    });
});
</script>
